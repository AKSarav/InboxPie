{
  "manifest_version": 2,
  "name": "InboxPie",
  "version": "1.0.2",
  "description": "Privacy-first email insights and cleanup. Explore patterns by year, month, domain, and sender — review locally, then act with confidence.",
  "author": "AKSarav",
  "browser_specific_settings": {
    "gecko": {
      "id": "app@inboxpie.com",
      "strict_min_version": "115.0"
    }
  },
  "permissions": [
    "accountsRead",
    "messagesRead",
    "messagesMove",
    "messagesDelete"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_title": "InboxPie - Open Dashboard"
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
